{
  "name": "ai-interview-server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "cd ../client && npm install --no-audit --no-fund && npm run build",
    "dev": "nodemon src/index.js",
    "test": "node --test ./test/app.test.cjs ./test/quizAnalytics.test.cjs ./test/assessmentAccess.test.cjs",
    "seed": "node scripts/seed.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "envalid": "^8.0.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.4",
    "pm2": "^5.4.2",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "xss-clean": "^0.1.4",
    "mammoth": "^1.4.21",
    "pdf-parse": "^1.1.1",
    "openai": "^4.10.0"
    ,
    "resend": "^1.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
